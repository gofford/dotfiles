# Allow common read-only GitHub inspection commands without prompting.
prefix_rule(
    pattern = ["gh", "pr", ["view", "diff", "checks"]],
    decision = "allow",
    justification = "Read-only pull request inspection is safe outside the sandbox.",
    match = [
        "gh pr view 123",
        "gh pr diff 123",
        "gh pr checks 123",
    ],
)

prefix_rule(
    pattern = ["gh", "issue", "view"],
    decision = "allow",
    justification = "Read-only issue inspection is safe outside the sandbox.",
    match = [
        "gh issue view 456",
    ],
)

prefix_rule(
    pattern = ["gh", "repo", "view"],
    decision = "allow",
    justification = "Read-only repo inspection is safe outside the sandbox.",
    match = [
        "gh repo view openai/codex",
    ],
)

prefix_rule(
    pattern = ["gh", "run", ["list", "view"]],
    decision = "allow",
    justification = "Read-only workflow run inspection is safe outside the sandbox.",
    match = [
        "gh run list",
        "gh run view 12345",
    ],
)

prefix_rule(
    pattern = ["gh", "browse"],
    decision = "allow",
    justification = "Opening GitHub pages is a low-risk inspection action.",
    match = [
        "gh browse",
        "gh browse 123",
    ],
)

# Allow explicit read-only GitHub API inspection for PR review threads and comments.
prefix_rule(
    pattern = ["gh", "api", "--method", "GET"],
    decision = "allow",
    justification = "Explicit GET requests to the GitHub API are safe outside the sandbox.",
    match = [
        "gh api --method GET repos/org/repo/pulls/123/comments",
        "gh api --method GET repos/org/repo/pulls/123/reviews",
        "gh api --method GET repos/org/repo/issues/123/comments",
    ],
)

# Allow PR drafting and metadata updates without prompting.
prefix_rule(
    pattern = ["gh", "pr", "create", "--draft"],
    decision = "allow",
    justification = "Creating draft pull requests is an expected publishing workflow.",
    match = [
        "gh pr create --draft --title title --body-file .github/pull_request_template.md",
    ],
)

prefix_rule(
    pattern = ["gh", "pr", "edit"],
    decision = "allow",
    justification = "Updating PR title and body is an expected publishing workflow.",
    match = [
        "gh pr edit 123 --title title --body-file .github/pull_request_template.md",
    ],
)

# Prompt before commands that can mutate remote state or create discussion.
prefix_rule(
    pattern = ["gh", ["pr", "issue"], "comment"],
    decision = "prompt",
    justification = "Remote comments should stay interactive.",
    match = [
        "gh pr comment 123 --body hello",
        "gh issue comment 456 --body hello",
    ],
)

prefix_rule(
    pattern = ["gh", "workflow", "run"],
    decision = "prompt",
    justification = "Triggering remote workflows should stay interactive.",
    match = [
        "gh workflow run ci.yml",
    ],
)

# Forbid destructive or finalizing GitHub actions from Codex.
prefix_rule(
    pattern = ["gh", "pr", ["merge", "close"]],
    decision = "forbidden",
    justification = "Do not merge or close pull requests from Codex.",
    match = [
        "gh pr merge 123",
        "gh pr close 123",
    ],
)

prefix_rule(
    pattern = ["gh", "repo", "delete"],
    decision = "forbidden",
    justification = "Do not delete repositories from Codex.",
    match = [
        "gh repo delete openai/codex",
    ],
)
