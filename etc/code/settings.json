{
    // get rid of annoying prompts
    "explorer.confirmDelete": false,
    "explorer.compactFolders": false,
    "explorer.confirmDragAndDrop": false,

    // terminal
    "terminal.external.osxExec": "iTerm2.app",
    "terminal.integrated.fontFamily": "MesloLGS NF",
    "terminal.integrated.fontSize": 13,

    // disable telemetry
    "telemetry.telemetryLevel": "off",

    // workspaces
    "workbench.colorTheme": "GitHub Dark Default",
    "workbench.startupEditor": "none",
    "workbench.tree.indent": 20,


    // autosave every second or so
    "files.autoSave": "afterDelay",

    // file assocations
    "workbench.editorAssociations": {
        "*.sql": "jinja-sql"
    },

    // python
    "python.interpreter.infoVisibility": "always",

    // gitlens
    "gitlens.showWelcomeOnInstall": false,
    "gitlens.plusFeatures.enabled": false,
    "gitlens.virtualRepositories.enabled": false,
    "gitlens.statusBar.enabled": false,

    // editor
    "editor.fontFamily": "Fira Code",
    "editor.fontLigatures": true,
    "editor.formatOnPaste": true,
    "editor.guides.bracketPairs": "active",
    "editor.linkedEditing": true,
    "editor.scrollBeyondLastLine": false,
    "editor.smoothScrolling": true,
    "editor.cursorStyle": "block",
    "editor.minimap.autohide": true,
    "editor.rulers": [88], //black
    "editor.accessibilitySupport": "off",

    // workbench
    "workbench.iconTheme": "vscode-icons",

    // window
    "window.nativeTabs": true,
    "window.zoomLevel": 0.3, // 10% larger than normal

    // misc extensions
    "indentRainbow.indicatorStyle": "light",

    // copilot
    "github.copilot.enable": {
        "*": true,
        "plaintext": false,
        "markdown": "true",
        "scminput": false
    },

    // security
    "security.workspace.trust.untrustedFiles": "open",

    // jupyter
    "jupyter.askForKernelRestart": false,

    // misc
    "l13Projects.confirmDeleteProject": false,

    // terraform - language specific
    "[terraform]": {
        "editor.defaultFormatter": "hashicorp.terraform",
        "editor.formatOnSave": false,
        "editor.formatOnSaveMode": "file",
    },
    "[terraform-vars]": {
        "editor.defaultFormatter": "hashicorp.terraform",
        "editor.formatOnSave": false,
        "editor.formatOnSaveMode": "file",
    },

    // ruff
    "ruff.lint.args": [
        "--extend-exclude=/**/site-packages/**/*.py",
    ],

    // markdownlint
    "markdownlint.config": {
        "MD033": false,
        "MD041": false,
        "MD045": false
    },
    "cloudcode.autoDependencies": "off"
}
